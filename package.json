{
  "name": "playwright-visual-testing",
  "version": "1.0.0",
  "description": "Visual regression testing for OrangeHRM using Playwright",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:update": "playwright test --update-snapshots",
    "test:ui": "playwright test --ui",
    "auth:refresh": "node -e \"try{require('fs').unlinkSync('.auth/user.json')}catch(e){}\" && playwright test --project=setup",
    "logs:clear": "node -e \"['info','error','test'].forEach(f=>{try{require('fs').unlinkSync('logs/'+f+'.log')}catch(e){}})\"",
    "report": "playwright show-report"
  },
  "keywords": [
    "playwright",
    "visual-testing",
    "visual-regression",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "winston": "^3.19.0"
  }
}
